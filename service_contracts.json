{
    "document_type": "service_contracts",
    "project_name": "Automated Mobile App Production Factory",
    "version": "1.1",
    "status": "approved",
    "services": [
      {
        "service_name": "discovery-cycle-service",
        "description": "The 'on' switch for the factory. Receives a signal from the CEO Dashboard to begin a new idea sourcing cycle.",
        "endpoint": "/start",
        "method": "POST",
        "input_schema": {
          "type": "object",
          "properties": {},
          "required": []
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "example": "success" },
            "message": { "type": "string", "example": "Discovery cycle initiated." }
          },
          "required": ["status", "message"]
        }
      },
      {
        "service_name": "cso-vetting-service",
        "description": "Acts as the Chief Strategy Officer. Vets a raw idea for mass-market appeal.",
        "endpoint": "/vet",
        "method": "POST",
        "input_schema": {
          "type": "object",
          "properties": {
            "raw_text": { "type": "string", "description": "The raw, unfiltered text of the user's idea or complaint." }
          },
          "required": ["raw_text"]
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "decision": { "type": "string", "enum": ["yes", "no"] }
          },
          "required": ["decision"]
        }
      },
      {
        "service_name": "cpo-analysis-service",
        "description": "Acts as the Chief Product Officer. Generates a complete product brief from a vetted idea.",
        "endpoint": "/analyze",
        "method": "POST",
        "input_schema": {
          "type": "object",
          "properties": {
            "raw_text": { "type": "string", "description": "The CSO-vetted text of the user's idea." }
          },
          "required": ["raw_text"]
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "ai_title": { "type": "string" },
            "ai_summary": { "type": "string" },
            "competition_analysis": { "type": "string" },
            "swot_analysis": {
              "type": "object",
              "properties": {
                "strengths": { "type": "array", "items": { "type": "string" } },
                "weaknesses": { "type": "array", "items": { "type": "string" } },
                "opportunities": { "type": "array", "items": { "type": "string" } },
                "threats": { "type": "array", "items": { "type": "string" } }
              },
              "required": ["strengths", "weaknesses", "opportunities", "threats"]
            }
          },
          "required": ["ai_title", "ai_summary", "competition_analysis", "swot_analysis"]
        }
      },
      {
        "service_name": "ai-developer-agent-service",
        "description": "Acts as the CTO/Head of Engineering. Orchestrates the entire app development pipeline.",
        "endpoint": "/kickoff-development",
        "method": "POST",
        "input_schema": {
          "type": "object",
          "properties": {
            "product_brief": {
              "type": "object",
              "description": "The complete product brief generated by the CPO.",
              "properties": {
                  "ai_title": { "type": "string" },
                  "ai_summary": { "type": "string" }
              },
              "required": ["ai_title", "ai_summary"]
            }
          },
          "required": ["product_brief"]
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "example": "success" },
            "message": { "type": "string", "example": "Development pipeline initiated." },
            "repo_url": { "type": "string", "format": "uri" }
          },
          "required": ["status", "repo_url"]
        }
      }
    ]
  }